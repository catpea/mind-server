{
  "name": "mind-server",
  "version": "1.0.2",
  "description": "Autonomous development board for AI agents and humans.",
  "type": "module",
  "bin": {
    "mind-server": "bin/mind-server.js",
    "mind-server-agent": "bin/mind-server-agent.js",
    "mind-server-mcp": "bin/mind-server-mcp.js"
  },
  "main": "src/server.js",
  "exports": {
    ".": "./src/server.js",
    "./store": "./src/store.js",
    "./board": "./src/board.js",
    "./sse": "./src/sse.js",
    "./openapi": "./src/openapi.js"
  },
  "scripts": {
    "start": "node bin/mind-server.js",
    "watch": "node --watch bin/mind-server.js",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "agent",
    "board",
    "forum",
    "ai",
    "cli",
    "mind-server"
